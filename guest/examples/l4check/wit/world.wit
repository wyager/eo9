// l4check — the transport-layer (eo9:net/l4) example: bind a UDP socket, send a DNS
// query for `example.com` to the QEMU user-net resolver (10.0.2.3), and report the
// answer; then attempt a TCP connection to the gateway's discard port and report its
// typed outcome. A DNS answer proves UDP datagrams travel both ways through whatever
// l4 provider the program is composed with (`net.virtio $ net.l4.over-l2` on metal);
// the TCP attempt proves the stack turns a refused/ignored SYN into a typed error
// rather than a trap. Capabilities: eo9:net/l4 only.
package eo9-examples:l4check@0.1.0;

/// Resolves `example.com` over the granted transport capability and reports what the
/// resolver answered, plus the typed outcome of a TCP connection attempt.
///
///   net.virtio $ net.l4.over-l2 $ l4check
world l4check {
    import eo9:net/l4@0.1.0;

    variant program-success {
        /// The resolver answered; carries the first A record (or an answer summary)
        /// plus the TCP attempt's outcome.
        resolved(string),
    }

    variant program-failure {
        /// The transport capability refused (e.g. composed over net.l2.deny).
        denied,
        /// A transport operation failed, carrying the l4 API's own error.
        net(string),
        /// Datagrams moved but no DNS answer came back.
        no-answer(string),
    }

    export main: async func() -> result<program-success, program-failure>;
}
