/// eo9:exec — the execution APIs: component algebra (unprivileged), compile and
/// task (privileged).
///
/// See SPEC.md: "Execution APIs". The interfaces follow the spec's sketches; the
/// `image` resource has been moved into a types-only `images` interface so that
/// importing `task` does not implicitly import the `compile` authority (see
/// plan/02-wit.md Decisions). `interface` is a WIT keyword, so the spec's
/// `import-need.interface` field is spelled `%interface` here.
///
/// Entrypoint convention: a binary's `main` and a provider's `configure` exports are
/// `async func` (see SPEC: WASM runtime) — anything that performs I/O must be async-lifted.
package eo9:exec@0.1.0;

/// Pure value manipulation on program bytecode (unprivileged).
interface component-algebra {
    /// An open program value: binary or provider.
    resource component;

    /// Which of the two module kinds a component is (see SPEC: binary or provider, never both).
    enum component-kind {
        binary,
        provider,
    }

    /// One interface a component still needs (a residual import).
    record import-need {
        /// The slot name this import is keyed by; defaults to the interface name
        /// when the import is unnamed (see SPEC: Capability slots) — e.g. "system-fs",
        /// or "eo9:net/net" for a default slot.
        slot: string,
        /// e.g. "eo9:net/net"
        %interface: string,
        /// semver it was built against (satisfied per the semver rule in the spec)
        version: string,
        /// mandatory vs. optional import
        required: bool,
    }

    /// One export slot: a name carrying an interface and version.
    record export-slot {
        name: string,
        %interface: string,
        version: string,
    }

    /// One named, typed argument of `main` (binary) or `configure` (provider).
    /// `ty` is WIT type text; it drives WAVE parsing of invocations.
    record arg-spec {
        name: string,
        ty: string,
    }

    /// One named, constant argument value, WAVE-encoded: a `configure` argument bound at
    /// compose time (here) or a `main` argument bound at spawn time (`task.spawn`). Always
    /// checked against the target's declared signature (its `arg-spec`s).
    record named-arg {
        name: string,
        value: string,
    }

    /// Kind, imports, exports, and argument signature of a component.
    record component-info {
        kind: component-kind,
        imports: list<import-need>,
        exports: list<export-slot>,
        args: list<arg-spec>,
    }

    /// A reference to an interface for `restrict` allow-lists, e.g. "eo9:fs/fs".
    /// An entry admits both the required and `-optional` flavor (see SPEC: only).
    record interface-ref {
        %interface: string,
        /// Absent means "any version of this interface".
        version: option<string>,
    }

    variant load-error {
        /// Not a valid Component Model component.
        invalid-component(string),
        /// Valid component, but not an Eo9 module (neither binary nor provider).
        not-an-eo9-module(string),
    }

    variant compose-error {
        /// The left operand is not a provider.
        not-a-provider,
        /// An export and the import it would satisfy have incompatible types.
        type-mismatch(string),
        internal(string),
    }

    variant restrict-error {
        /// Required residual imports outside the allow-list (the compose-time error of `only`),
        /// naming the offenders.
        required-outside-allow-list(list<string>),
        invalid-allow-list(string),
        internal(string),
    }

    variant rename-error {
        no-such-slot(string),
        slot-collision(string),
        internal(string),
    }

    variant configure-error {
        /// The component is not a provider.
        not-a-provider,
        /// The provider exports no config interface — it is unconfigurable, or was already
        /// configured (a configured provider no longer exposes one).
        no-config-interface,
        /// An argument failed WAVE parsing or type-checking against the configure signature,
        /// or a required argument is missing / an unknown one was given.
        invalid-args(string),
        internal(string),
    }

    load:     func(image: list<u8>) -> result<component, load-error>;
    save:     func(c: borrow<component>) -> list<u8>;
    describe: func(c: borrow<component>) -> component-info;

    /// `$` — composition: satisfy `c`'s imports from `p`'s matching exports (see SPEC).
    compose:  func(p: component, c: component) -> result<component, compose-error>;
    /// `&` — environment extension: `base` extended and, where they overlap, overridden by `layer`.
    extend:   func(base: component, layer: component) -> result<component, compose-error>;
    /// `only` — bound `c` to a fixed allow-list of interfaces.
    restrict: func(c: component, allow: list<interface-ref>) -> result<component, restrict-error>;
    /// `rename a b` — relabel slot `old-name` to `new-name`, on imports and exports alike.
    /// (`from` is a WIT keyword, hence the longer parameter names.)
    rename:   func(c: component, old-name: string, new-name: string) -> result<component, rename-error>;
    /// Bind a provider's exported config interface with constant, WAVE-typed argument values:
    /// returns a new provider with those constants baked in that re-exports only the API — the
    /// config interface is no longer visible, so the consumer can neither observe nor re-run the
    /// configuration. An invalid or ill-typed argument fails here, at compose time, before the
    /// consumer ever runs (see SPEC: Binary or provider, never both).
    configure: func(p: component, args: list<named-arg>) -> result<component, configure-error>;
}

/// Opaque compiled-artifact type, shared by `compile` (which mints images) and
/// `task` (which admits them for execution). Types-only so that holding Task
/// does not imply holding Compile.
interface images {
    /// An opaque compiled artifact; admitted for execution via `task`, never read back as bytes.
    resource image;
}

/// Codegen (privileged): asking the TCB to generate native code. Holding Compile
/// is what makes a program a *native* executor (see SPEC: Execution APIs).
interface compile {
    use component-algebra.{component};
    use images.{image};

    /// Options select debug info / safepoint maps, i.e. how inspectable the native task is.
    record compile-opts {
        debug-info: bool,
        safepoint-maps: bool,
    }

    variant compile-error {
        /// The component is a provider, not a binary.
        not-a-binary,
        /// The component is not closed: residual required imports, named.
        not-closed(list<string>),
        codegen(string),
    }

    /// `c` must be a *closed binary*: every capability decision was already made — inspectably —
    /// with the component algebra.
    compile: func(c: component, opts: compile-opts) -> result<image, compile-error>;
}

/// Spawning and driving native tasks (privileged, paired with `compile`).
interface task {
    use component-algebra.{named-arg};
    use images.{image};

    resource task;

    /// A WAVE-encoded value carrying its WIT type text, so an outcome can outlive its component.
    record wave-value {
        ty: string,
        value: string,
    }

    /// A run that never returned an outcome of its own. This is the executor's view —
    /// a program cannot report its own trap (see SPEC: Arguments and outcomes).
    variant abnormal-exit {
        /// The task trapped; the payload is the trap reason.
        trapped(string),
        /// The task was killed before finishing.
        killed,
    }

    /// A program's outcome, as a flat three-way variant (see SPEC: Arguments and outcomes).
    /// `success` and `failure` carry the program's own success/failure variants, WAVE-rendered
    /// with their type; `abnormal` covers runs that never returned.
    variant program-outcome {
        success(wave-value),
        failure(wave-value),
        abnormal(abnormal-exit),
    }

    /// Static resource limits, fixed at spawn. CPU is not here — CPU is fuel, and fuel is donated.
    record spawn-limits {
        /// Ceiling on linear-memory growth, enforced at memory.grow.
        max-memory: option<u64>,
    }

    variant spawn-error {
        /// Argument WAVE parse / type-check failure against main's signature.
        bad-arguments(string),
        internal(string),
    }

    /// `args` are main's named, typed arguments, WAVE-encoded and checked against main's signature.
    /// The image is only borrowed: one cached image can be spawned any number of times.
    spawn: func(i: borrow<image>, args: list<named-arg>, limits: spawn-limits) -> result<task, spawn-error>;

    variant resume-outcome {
        out-of-fuel,
        blocked,
        done(program-outcome),
    }

    /// Donate `fuel` to the task and run it now, on the caller's own CPU time; returns when the
    /// fuel is spent, the task blocks on I/O, or it finishes. Fuel is conserved — a scheduler can
    /// only donate fuel it was itself donated — so CPU budgets compose down the task tree.
    /// Fuel-metered yields keep interleaving deterministic.
    resume: func(t: borrow<task>, fuel: u64) -> resume-outcome;

    /// Returns when a blocked task can make progress.
    runnable: async func(t: borrow<task>);

    /// Returns when the task finishes.
    wait: async func(t: borrow<task>) -> program-outcome;

    /// Kill the task; returns its final outcome — `abnormal(killed)` unless the task had
    /// already finished. A killed task never observes anything again (see SPEC: Kill and linearity).
    kill: async func(t: borrow<task>) -> program-outcome;

    // TODO (SPEC): the multi-core rule (a task is resumed by at most one scheduler at a time);
    // the thread-spawn capability for intra-task parallelism (eo9:threads).
}
